# Copy to .env in project root and apps/api/.env

# PostgreSQL — Supabase free tier (use Session pooler URI from dashboard, NOT direct host on Windows)
# Example (pooler host may be aws-0 OR aws-1 — copy exact host from Supabase Connect → Session pooler):
# DATABASE_URL="postgresql://postgres.[project-ref]:[PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres?schema=public&sslmode=require"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vidyasetu?schema=public"

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# API
API_PORT=3001
API_URL="http://localhost:3001"
CORS_ORIGIN="http://localhost:3000"

# Frontend (Next.js)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# File storage — local free dev; swap to S3/MinIO/Supabase Storage via env only
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./uploads"
# STORAGE_ENDPOINT=""
# STORAGE_BUCKET=""
# STORAGE_ACCESS_KEY=""
# STORAGE_SECRET_KEY=""
# STORAGE_PUBLIC_URL=""

# Super admin seed (first run only)
SEED_SUPER_ADMIN_EMAIL="admin@vidyasetu.local"
SEED_SUPER_ADMIN_PASSWORD="ChangeMe123!"
